# Configurações opcionais. Na Vercel, o modo navegador é ativado automaticamente.
# No modo local, o Combinix cria database/.secret_key automaticamente.
COMBINIX_SECRET_KEY=troque-por-um-segredo-longo
COMBINIX_DEBUG=0
COMBINIX_HOST=127.0.0.1
COMBINIX_PORT=5000

# Use browser para simular localmente a persistência web com IndexedDB.
# COMBINIX_STORAGE_MODE=browser
